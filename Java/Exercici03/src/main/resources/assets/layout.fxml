<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="500.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.project.Controller">
   <children>
      <VBox AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
               <content>
                  <VBox fx:id="messagesBox" fillWidth="true" spacing="10">
                     <padding>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                     </padding>
                  </VBox>
               </content>
            </ScrollPane>
            
            <!-- Thinking indicator -->
            <Label fx:id="thinkingLabel" text="Thinking..." style="-fx-text-fill: blue; -fx-font-weight: bold; -fx-padding: 5;" visible="false" managed="false" />
            
            <!-- Image preview -->
            <HBox fx:id="imagePreviewBox" spacing="10" alignment="CENTER_LEFT" style="-fx-padding: 5; -fx-background-color: #f5f5f5;">
               <children>
                  <Label text="Imatge seleccionada:" />
                  <ImageView fx:id="imagePreview" fitHeight="80" fitWidth="80" preserveRatio="true" />
                  <Button text="X" onAction="#resetImageAttributes" styleClass="icon-button" />
               </children>
            </HBox>
            
            <HBox styleClass="input-bar" spacing="5" alignment="CENTER">
               <children>
                  <Button fx:id="buttonPicture" onAction="#loadImage" styleClass="icon-button">
                     <graphic>
                        <ImageView fitHeight="20" fitWidth="20" preserveRatio="true" />
                     </graphic>
                  </Button>
                  <TextField fx:id="textFieldPrompt" styleClass="text-field" promptText="Escriu el teu missatge..." HBox.hgrow="ALWAYS" />
                  <Button fx:id="buttonSendRequest" mnemonicParsing="false" onAction="#sendRequest" styleClass="icon-button">
                     <graphic>
                        <ImageView fitHeight="20" fitWidth="20" preserveRatio="true" />
                     </graphic>
                  </Button>
                  <Button fx:id="buttonBreak" mnemonicParsing="false" onAction="#callBreak" styleClass="icon-button">
                     <graphic>
                        <ImageView fitHeight="20" fitWidth="20" preserveRatio="true" />
                     </graphic>
                  </Button>
               </children>
               <padding>
                  <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
               </padding>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>